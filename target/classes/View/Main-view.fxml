<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #0F1117;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.2-ea" fx:controller="Controller.MainController">

    <top>
        <HBox spacing="0" style="-fx-background-color: #0F1117;                      -fx-border-color: #1E2235;                      -fx-border-width: 0 0 1 0;                      -fx-min-height: 64;                      -fx-alignment: center-left;">

            <HBox style="-fx-background-color: #6C63FF;                          -fx-min-width: 4;                          -fx-min-height: 64;" />

            <HBox spacing="12" style="-fx-padding: 0 24;                          -fx-alignment: center-left;                          -fx-min-height: 64;">
                <Label style="-fx-text-fill: #6C63FF; -fx-font-size: 22;" text="⬡" />
                <VBox style="-fx-alignment: center-left;">
                    <Label style="-fx-text-fill: #FFFFFF;                                   -fx-font-size: 15;                                   -fx-font-weight: bold;" text="EventosOnline" />
                    <Label style="-fx-text-fill: #6B7280; -fx-font-size: 10;" text="Plataforma de gestión de eventos" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="8" style="-fx-alignment: center; -fx-padding: 0 24 0 0;">
                <Label fx:id="resumenLabel" style="-fx-text-fill: #9CA3AF;                               -fx-font-size: 11;                               -fx-background-color: #1E2235;                               -fx-padding: 6 14;                               -fx-background-radius: 20;" />
            </HBox>
        </HBox>
    </top>

    <center>
        <TabPane style="-fx-background-color: #0F1117;" tabClosingPolicy="UNAVAILABLE">
            <Tab text="  👤  Usuario  ">
                <content>
                    <fx:include source="user-view.fxml" />
                </content>
            </Tab>
            <Tab text="  ⚙  Administrador  ">
                <content>
                    <fx:include source="admin-view.fxml" />
                </content>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
