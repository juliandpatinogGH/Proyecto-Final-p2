<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.UsuarioController"
            style="-fx-background-color: #0F1117;">
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #0F1117;
                           -fx-background: #0F1117;">
            <content>
                <VBox spacing="16"
                      style="-fx-padding: 20; -fx-background-color: #0F1117;">

                    <!-- SESION Y PERFIL -->
                    <VBox style="-fx-background-color: #161B2E;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #1E2235;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <HBox style="-fx-padding: 16 20 12 20;
                                     -fx-border-color: #1E2235;
                                     -fx-border-width: 0 0 1 0;
                                     -fx-alignment: center-left;">
                            <Label text="👤  Sesión y Perfil"
                                   style="-fx-text-fill: #FFFFFF;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />
                        </HBox>
                        <VBox spacing="12" style="-fx-padding: 16 20;">
                            <HBox spacing="10" style="-fx-alignment: center-left;">
                                <Label text="Usuario activo"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 11; -fx-min-width: 90;" />
                                <ComboBox fx:id="comboUsuario" prefWidth="260"
                                          style="-fx-background-color: #1E2235;
                                                 -fx-text-fill: #FFFFFF;
                                                 -fx-border-color: #2D3561;
                                                 -fx-border-radius: 6;
                                                 -fx-background-radius: 6;" />
                                <Button text="Actualizar perfil" onAction="#aplicarPerfil"
                                        style="-fx-background-color: #6C63FF;
                                               -fx-text-fill: #FFFFFF;
                                               -fx-font-weight: bold;
                                               -fx-font-size: 11;
                                               -fx-padding: 7 16;
                                               -fx-background-radius: 6;
                                               -fx-cursor: hand;" />
                            </HBox>
                            <GridPane hgap="10" vgap="10">
                                <Label text="Nombre" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" />
                                <TextField fx:id="txtNombrePerfil" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"
                                           style="-fx-background-color: #1E2235;
                                                  -fx-text-fill: #FFFFFF;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6;
                                                  -fx-background-radius: 6;
                                                  -fx-padding: 7 10;" />
                                <Label text="Correo" GridPane.rowIndex="0" GridPane.columnIndex="2"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" />
                                <TextField fx:id="txtCorreoPerfil" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="200"
                                           style="-fx-background-color: #1E2235;
                                                  -fx-text-fill: #FFFFFF;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6;
                                                  -fx-background-radius: 6;
                                                  -fx-padding: 7 10;" />
                                <Label text="Teléfono" GridPane.rowIndex="0" GridPane.columnIndex="4"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" />
                                <TextField fx:id="txtTelefonoPerfil" GridPane.rowIndex="0" GridPane.columnIndex="5" prefWidth="140"
                                           style="-fx-background-color: #1E2235;
                                                  -fx-text-fill: #FFFFFF;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6;
                                                  -fx-background-radius: 6;
                                                  -fx-padding: 7 10;" />
                            </GridPane>
                            <HBox spacing="10"
                                  style="-fx-background-color: #1E2235;
                                         -fx-padding: 12 14;
                                         -fx-background-radius: 8;
                                         -fx-alignment: center-left;">
                                <Label text="Nuevo usuario"
                                       style="-fx-text-fill: #6C63FF; -fx-font-size: 11; -fx-font-weight: bold;" />
                                <TextField fx:id="txtNombreRegistro" promptText="Nombre" prefWidth="160"
                                           style="-fx-background-color: #161B2E;
                                                  -fx-text-fill: #FFFFFF;
                                                  -fx-prompt-text-fill: #4B5563;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6;
                                                  -fx-background-radius: 6;
                                                  -fx-padding: 7 10;" />
                                <TextField fx:id="txtCorreoRegistro" promptText="Correo" prefWidth="180"
                                           style="-fx-background-color: #161B2E;
                                                  -fx-text-fill: #FFFFFF;
                                                  -fx-prompt-text-fill: #4B5563;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6;
                                                  -fx-background-radius: 6;
                                                  -fx-padding: 7 10;" />
                                <TextField fx:id="txtTelefonoRegistro" promptText="Teléfono" prefWidth="130"
                                           style="-fx-background-color: #161B2E;
                                                  -fx-text-fill: #FFFFFF;
                                                  -fx-prompt-text-fill: #4B5563;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6;
                                                  -fx-background-radius: 6;
                                                  -fx-padding: 7 10;" />
                                <Button text="Registrar usuario" onAction="#registrarUsuario"
                                        style="-fx-background-color: #10B981;
                                               -fx-text-fill: #FFFFFF;
                                               -fx-font-weight: bold;
                                               -fx-font-size: 11;
                                               -fx-padding: 7 16;
                                               -fx-background-radius: 6;
                                               -fx-cursor: hand;" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- EVENTOS Y COMPRA -->
                    <VBox style="-fx-background-color: #161B2E;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #1E2235;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <HBox style="-fx-padding: 16 20 12 20;
                                     -fx-border-color: #1E2235;
                                     -fx-border-width: 0 0 1 0;
                                     -fx-alignment: center-left;">
                            <Label text="🎫  Eventos y Compra"
                                   style="-fx-text-fill: #FFFFFF;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />
                        </HBox>
                        <VBox spacing="12" style="-fx-padding: 16 20;">
                            <HBox spacing="8" style="-fx-alignment: center-left;">
                                <TextField fx:id="txtFiltroCiudad" promptText="Ciudad" prefWidth="120"
                                           style="-fx-background-color: #1E2235; -fx-text-fill: #FFFFFF;
                                                  -fx-prompt-text-fill: #4B5563; -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;" />
                                <TextField fx:id="txtFiltroCategoria" promptText="Categoría" prefWidth="120"
                                           style="-fx-background-color: #1E2235; -fx-text-fill: #FFFFFF;
                                                  -fx-prompt-text-fill: #4B5563; -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;" />
                                <TextField fx:id="txtFiltroPrecio" promptText="Precio máx." prefWidth="110"
                                           style="-fx-background-color: #1E2235; -fx-text-fill: #FFFFFF;
                                                  -fx-prompt-text-fill: #4B5563; -fx-border-color: #2D3561;
                                                  -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;" />
                                <DatePicker fx:id="filtroFecha" promptText="Fecha" prefWidth="130"
                                            style="-fx-background-color: #1E2235; -fx-background-radius: 6;" />
                                <Button text=" Filtrar" onAction="#aplicarFiltros"
                                        style="-fx-background-color: #6C63FF; -fx-text-fill: #FFFFFF;
                                               -fx-font-weight: bold; -fx-font-size: 11;
                                               -fx-padding: 7 16; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button text="✕ Limpiar" onAction="#limpiarFiltros"
                                        style="-fx-background-color: #1E2235; -fx-text-fill: #9CA3AF;
                                               -fx-font-size: 11; -fx-padding: 7 16;
                                               -fx-background-radius: 6; -fx-cursor: hand;" />
                            </HBox>

                            <SplitPane dividerPositions="0.58" prefHeight="240"
                                       style="-fx-background-color: transparent;">
                                <TableView fx:id="tablaEventos"
                                           style="-fx-background-color: #1E2235;
                                                  -fx-border-color: #2D3561;
                                                  -fx-border-radius: 8;">
                                    <columns>
                                        <TableColumn fx:id="colEventoNombre" text="Evento" prefWidth="160" />
                                        <TableColumn fx:id="colEventoCategoria" text="Categoría" prefWidth="110" />
                                        <TableColumn fx:id="colEventoCiudad" text="Ciudad" prefWidth="100" />
                                        <TableColumn fx:id="colEventoFecha" text="Fecha" prefWidth="95" />
                                        <TableColumn fx:id="colEventoDesde" text="Desde $" prefWidth="85" />
                                    </columns>
                                </TableView>
                                <TextArea fx:id="txtDetalleEvento" editable="false" wrapText="true"
                                          style="-fx-background-color: #1E2235;
                                                 -fx-text-fill: #D1D5DB;
                                                 -fx-font-size: 11;
                                                 -fx-border-color: #2D3561;" />
                            </SplitPane>

                            <HBox spacing="10" style="-fx-alignment: center-left;">
                                <ComboBox fx:id="comboZona" prefWidth="220"
                                          style="-fx-background-color: #1E2235; -fx-background-radius: 6;" />
                                <ComboBox fx:id="comboAsiento" prefWidth="130"
                                          style="-fx-background-color: #1E2235; -fx-background-radius: 6;" />
                                <ComboBox fx:id="comboPago" prefWidth="150"
                                          style="-fx-background-color: #1E2235; -fx-background-radius: 6;" />
                            </HBox>

                            <HBox spacing="6"
                                  style="-fx-background-color: #1E2235;
                                         -fx-padding: 10 14;
                                         -fx-background-radius: 8;
                                         -fx-alignment: center-left;">
                                <Label text="Servicios:"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 11;" />
                                <CheckBox fx:id="chkVip" text="VIP"
                                          style="-fx-text-fill: #F59E0B;" />
                                <CheckBox fx:id="chkSeguro" text="Seguro"
                                          style="-fx-text-fill: #10B981;" />
                                <CheckBox fx:id="chkMerch" text="Merch"
                                          style="-fx-text-fill: #6C63FF;" />
                                <CheckBox fx:id="chkParqueadero" text="Parqueadero"
                                          style="-fx-text-fill: #3B82F6;" />
                            </HBox>

                            <HBox spacing="10" style="-fx-alignment: center-left;">
                                <Label fx:id="lblTotalCompra" text="Total: $0"
                                       style="-fx-text-fill: #6C63FF;
                                              -fx-font-size: 16;
                                              -fx-font-weight: bold;
                                              -fx-padding: 0 16 0 0;" />
                                <Button text="✓ Crear y Pagar" onAction="#crearCompra"
                                        style="-fx-background-color: #6C63FF; -fx-text-fill: #FFFFFF;
                                               -fx-font-weight: bold; -fx-font-size: 12;
                                               -fx-padding: 9 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                                <Button text="Confirmar" onAction="#confirmarCompra"
                                        style="-fx-background-color: #10B981; -fx-text-fill: #FFFFFF;
                                               -fx-font-weight: bold; -fx-font-size: 11;
                                               -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;" />
                                <Button text="Cancelar" onAction="#cancelarCompra"
                                        style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF;
                                               -fx-font-weight: bold; -fx-font-size: 11;
                                               -fx-padding: 9 16; -fx-background-radius: 8; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- HISTORIAL Y REPORTES -->
                    <VBox style="-fx-background-color: #161B2E;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #1E2235;
                                 -fx-border-radius: 12;
                                 -fx-border-width: 1;">
                        <HBox style="-fx-padding: 16 20 12 20;
                                     -fx-border-color: #1E2235;
                                     -fx-border-width: 0 0 1 0;
                                     -fx-alignment: center-left;">
                            <Label text="📋  Historial y Reportes"
                                   style="-fx-text-fill: #FFFFFF;
                                          -fx-font-size: 13;
                                          -fx-font-weight: bold;" />
                        </HBox>
                        <VBox spacing="12" style="-fx-padding: 16 20;">
                            <TableView fx:id="tablaCompras" prefHeight="180"
                                       style="-fx-background-color: #1E2235;
                                              -fx-border-color: #2D3561;
                                              -fx-border-radius: 8;">
                                <columns>
                                    <TableColumn fx:id="colCompraId" text="ID" prefWidth="90" />
                                    <TableColumn fx:id="colCompraEvento" text="Evento" prefWidth="220" />
                                    <TableColumn fx:id="colCompraEstado" text="Estado" prefWidth="130" />
                                    <TableColumn fx:id="colCompraTotal" text="Total" prefWidth="110" />
                                    <TableColumn fx:id="colCompraFecha" text="Fecha" prefWidth="120" />
                                </columns>
                            </TableView>
                            <HBox spacing="10" style="-fx-alignment: center-left;">
                                <Button text="⬇ Exportar CSV" onAction="#exportarCSV"
                                        style="-fx-background-color: #1E2235; -fx-text-fill: #10B981;
                                               -fx-border-color: #10B981; -fx-border-radius: 6;
                                               -fx-font-weight: bold; -fx-font-size: 11;
                                               -fx-padding: 7 16; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Button text="⬇ Exportar PDF" onAction="#exportarPDF"
                                        style="-fx-background-color: #1E2235; -fx-text-fill: #EF4444;
                                               -fx-border-color: #EF4444; -fx-border-radius: 6;
                                               -fx-font-weight: bold; -fx-font-size: 11;
                                               -fx-padding: 7 16; -fx-background-radius: 6; -fx-cursor: hand;" />
                                <Label fx:id="lblMensajeUsuario"
                                       style="-fx-text-fill: #10B981; -fx-font-size: 11;" />
                            </HBox>
                        </VBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>